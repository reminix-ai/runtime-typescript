{
  "name": "reminix-runtime-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "description": "Reminix Runtime - Monorepo",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --filter=!integration-tests",
    "test:integration": "pnpm --filter integration-tests test",
    "test:integration:openai": "pnpm --filter integration-tests test:openai",
    "test:integration:anthropic": "pnpm --filter integration-tests test:anthropic",
    "test:integration:langchain": "pnpm --filter integration-tests test:langchain",
    "test:integration:langgraph": "pnpm --filter integration-tests test:langgraph",
    "test:integration:vercel-ai": "pnpm --filter integration-tests test:vercel-ai",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.7.4",
    "typescript": "^5.9.3"
  }
}
